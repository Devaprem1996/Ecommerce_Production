# Application Environment
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000

# Database Configuration (Neon/Local PostgreSQL)
# For Prisma: Use pooler URL for DATABASE_URL and direct URL for DIRECT_URL
DATABASE_URL="postgresql://username:password@hostname:port/database_name?sslmode=require"
DIRECT_URL="postgresql://username:password@hostname:port/database_name?sslmode=require"

# JWT Secrets
JWT_SECRET="generate-high-entropy-jwt-secret-string"
REFRESH_TOKEN_SECRET="generate-high-entropy-refresh-token-secret-string"

# OAuth Configuration (Google Console Developer Portal)
GOOGLE_CLIENT_ID="google-client-id"
GOOGLE_CLIENT_SECRET="google-client-secret"

# Payment Gateway Configuration (Razorpay Sandbox/Production)
RAZORPAY_KEY_ID="rzp_test_key_id"
RAZORPAY_KEY_SECRET="rzp_test_key_secret"
RAZORPAY_WEBHOOK_SECRET="rzp_webhook_secret_key"

# Cloud Storage Configuration (Cloudinary Assets)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
